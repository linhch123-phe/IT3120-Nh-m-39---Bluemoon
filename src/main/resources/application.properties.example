# Sao chép file này thành application.properties và điền thông tin của bạn
# File application.properties KHÔNG được commit lên Git

spring.application.name=BlueMoon

# ── Database ────────────────────────────────────────────────
spring.datasource.url=jdbc:mysql://localhost:3306/bluemoon?useSSL=false&serverTimezone=Asia/Ho_Chi_Minh&allowPublicKeyRetrieval=true
spring.datasource.username=root
spring.datasource.password=your_password
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# ── JPA / Hibernate ──────────────────────────────────────────
# validate: Hibernate chỉ kiểm tra entity khớp schema, KHÔNG tự sửa DB
# Mọi thay đổi schema phải qua file SQL trong database/
spring.jpa.hibernate.ddl-auto=validate
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true

# ── Tài khoản Admin mặc định ─────────────────────────────────
# Được tạo tự động khi app khởi động lần đầu (nếu chưa có user nào trong DB)
# Đổi thành mật khẩu mạnh trước khi deploy
app.admin.username=admin
app.admin.password=your_admin_password
app.admin.fullname=Quản trị viên

# ── Server ───────────────────────────────────────────────────
server.port=8080
